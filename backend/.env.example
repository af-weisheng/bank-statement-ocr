# ─── Runtime ─────────────────────────────────────────────────────────────────

# "development" | "test" | "production"
NODE_ENV=development

# Port the Express server listens on (local dev only; Vercel manages ports).
PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
#
# Full PostgreSQL connection string. The app reads only DATABASE_URL — individual
# DB_HOST / DB_PORT / DB_NAME variables are not used.
#
# Local development (plain TCP, no SSL):
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/bank_statement_ocr
#
# Neon (recommended for Vercel) — use the POOLED connection string so each
# serverless Lambda instance doesn't open a dedicated connection:
# DATABASE_URL=postgresql://user:pass@ep-xxx-yyy.pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
#
# Test database (used when NODE_ENV=test if DATABASE_URL_TEST is set):
# DATABASE_URL_TEST=postgresql://postgres:your_password@localhost:5432/bank_statement_ocr_test

# ─── JWT ─────────────────────────────────────────────────────────────────────
#
# Secret used to sign magic-link and session tokens.
# MUST be changed in production — use a random 64-character hex string:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Session token lifetime (Vercel / jsonwebtoken notation: Xs, Xm, Xh, Xd).
JWT_EXPIRES_IN=7d

# ─── SMTP (magic-link email delivery) ────────────────────────────────────────
#
# Any SMTP-compatible provider works. Examples:
#   Gmail:      smtp.gmail.com  port 587  SMTP_SECURE=false
#   Brevo:      smtp-relay.brevo.com  port 587
#   Resend:     smtp.resend.com  port 465  SMTP_SECURE=true
#   Mailgun:    smtp.mailgun.org  port 587
#   SendGrid:   smtp.sendgrid.net  port 587  SMTP_USER=apikey
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# true for port 465 (SMTPS), false for port 587 (STARTTLS)
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
# Gmail: generate an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on your Google account)
SMTP_PASS=your_app_password_here
SMTP_FROM="Bank Statement OCR <noreply@example.com>"

# ─── CORS ────────────────────────────────────────────────────────────────────
#
# Comma-separated list of origins Express will accept. No trailing slashes.
#
# Local dev:
ALLOWED_ORIGINS=http://localhost:3000
#
# Production — add your Vercel deployment URL and any custom domain:
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://yourdomain.com

# ─── Super-admin seed ────────────────────────────────────────────────────────
#
# Email address inserted as is_super_admin=true when you first run the migration.
#   npm run db:migrate   (local)
#   npm run db:migrate:prod   (production, after building)
SUPER_ADMIN_EMAIL=admin@example.com

# ─── File upload ─────────────────────────────────────────────────────────────
#
# Maximum upload size in megabytes. Files are processed in-memory (not stored
# on disk), so this also acts as a memory guard.
MAX_FILE_SIZE_MB=10
