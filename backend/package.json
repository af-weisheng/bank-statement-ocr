    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.1.392",
    "pg": "^8.11.5",
    "sharp": "^0.33.3",
    "tesseract.js": "^5.0.4",
    "uuid": "^9.0.1"
