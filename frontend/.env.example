# ─── API base URL ────────────────────────────────────────────────────────────
#
# Local development
#   The Vite dev server proxies every /api/* request to the backend, so you
#   don't strictly need this variable locally — leave it blank or set it to the
#   backend URL if you run API calls outside the Vite server (e.g. in Vitest).
VITE_API_URL=http://localhost:4000/api

# Production (Vercel)
#   The frontend and API share the same domain; vercel.json rewrites /api/*
#   to the serverless function. Set this variable in the Vercel dashboard to a
#   relative path so the deployed frontend hits the same origin.
#
# VITE_API_URL=/api
